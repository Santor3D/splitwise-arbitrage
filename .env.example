# Splitwise auth. Use an API key from https://secure.splitwise.com/apps.
# OAuth2 fields are left here for a future OAuth flow; api_key mode uses SPLITWISE_API_KEY.
SPLITWISE_AUTH_MODE=api_key
SPLITWISE_API_KEY=
SPLITWISE_CONSUMER_KEY=
SPLITWISE_CONSUMER_SECRET=
SPLITWISE_OAUTH2_ACCESS_TOKEN=
SPLITWISE_BASE_URL=https://secure.splitwise.com/api/v3.0

# Splitwise group ids. Run `python -m splitwise_arbitrage discover` to list them.
SPLITWISE_OFFICE_GROUP_ID=
SPLITWISE_OFFICE_SERVICES_GROUP_ID=
SPLITWISE_OFFICE_GROUP_NAME=Office
SPLITWISE_OFFICE_SERVICES_GROUP_NAME=Office Servicios

# Alias -> Splitwise user id. Fill ids with the ids printed by `discover`.
SPLITWISE_USERS_JSON={"Gordo":0,"Reski":0,"Fran":0,"Teo":0,"dummyMeli":0,"dummyBenja":0,"dummyJavi":0,"dummyFeli":0,"dummyIanchi":0,"dummyPablo":0}

# Editable business groups. Employees are the users/dummies whose balances are
# transferred to the admins. Multiple admins split each employee balance equally.
BUSINESS_GROUPS_JSON={"Sensus3D":{"admins":["Reski","Gordo"],"employees":["dummyBenja","dummyJavi","dummyFeli","dummyIanchi","dummyPablo"]},"InmoClick":{"admins":["Fran"],"employees":["dummyMeli"]},"TiendaNube":{"admins":["Teo"],"employees":[]}}

# Only these aliases are moved from Office Servicios into Office after dummy cleanup.
CROSS_GROUP_ALIASES=Gordo,Reski,Fran,Teo

# Runtime controls.
CURRENCY_CODE=ARS
MIN_AMOUNT=0.01
DRY_RUN=true
SPLITWISE_MARK_AS_PAYMENT=false
STATE_FILE=state/pending_run.json

# Used by `python -m splitwise_arbitrage schedule`.
SCHEDULE_TIME=06:00
SCHEDULE_TIMEZONE=America/Buenos_Aires
